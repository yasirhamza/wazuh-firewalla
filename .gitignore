# ===========================================
# Secrets and Credentials
# ===========================================

# Environment files (contain passwords/tokens)
.env
.env.*
*.env
!.env.example

# Secrets directory
secrets/

# ===========================================
# SSL/TLS Certificates
# ===========================================

# All private keys
*.key
*-key.pem

# Certificate directory (regenerated per deployment)
config/certs/

